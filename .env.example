# ==========================================================
# Automação de Saídas UNASP - Variáveis de Ambiente (raiz)
# Copie este arquivo para .env e preencha os valores.
# ==========================================================

# --- Segurança ---
# Segredo de assinatura do JWT. Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-jwt-secret

# Chave AES usada para criptografar as credenciais do UNASP armazenadas.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-fernet-key

# --- Banco de dados ---
# Local dev (SQLite):
DATABASE_URL=sqlite:///./saidas.db
# Production (Supabase Postgres, Session mode port 5432 — set in Render Dashboard):
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# --- Validade do token (minutos) ---
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Automação / Site alvo ---
PENSIONATO_BASE_URL=https://pensionato.unasp.edu.br/
# Roda o navegador headless (true) ou visível para depuração (false)
PLAYWRIGHT_HEADLESS=true
# Onde as imagens de comprovante de envio são armazenadas
SCREENSHOTS_DIR=./screenshots

# --- Agendador ---
# Fuso horário usado em todas as tarefas agendadas (estilo cron)
SCHEDULER_TIMEZONE=America/Sao_Paulo

# --- CORS (origem do frontend) ---
# Local: http://localhost:5173
# Production (Render): https://your-app.vercel.app
# Multiple origins: comma-separated
FRONTEND_ORIGIN=http://localhost:5173

# Optional regex for Vercel preview URLs (set on Render in production)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
